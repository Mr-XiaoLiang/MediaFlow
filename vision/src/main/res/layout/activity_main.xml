<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background"
    tools:background="#3f00"
    tools:context=".MainActivity">

    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager2"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </eightbitlab.com.blurview.BlurTarget>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startGuideLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endGuideLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topGuideLine"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottomGuideLine"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="16dp" />

    <com.lollipop.common.ui.view.RoundOutlineLayout
        android:id="@+id/flowButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="4dp"
        android:background="@color/button_background"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@id/tabBar"
        app:layout_constraintEnd_toEndOf="@id/endGuideLine">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/flowButtonBlur"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/mediaflow_fab"
                app:tint="@color/button_text" />
        </eightbitlab.com.blurview.BlurView>
    </com.lollipop.common.ui.view.RoundOutlineLayout>

    <com.lollipop.common.ui.view.RoundOutlineLayout
        android:id="@+id/tabBar"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginBottom="10dp"
        android:background="@color/button_background"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="@id/bottomGuideLine"
        app:layout_constraintStart_toStartOf="@id/startGuideLine">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/tabBarBlur"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:padding="4dp">

            <com.lollipop.common.ui.view.TabGroup
                android:id="@+id/tabGroup"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="8dp"
                app:tabColor="@color/button_slider">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/publicVideoTab"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:padding="11dp"
                    android:src="@drawable/movie_24"
                    app:tint="@color/button_text" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/publicPhotoTab"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:padding="11dp"
                    android:src="@drawable/photo_24"
                    app:tint="@color/button_text" />

                <FrameLayout
                    android:id="@+id/privateVideoTab"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|bottom"
                        android:src="@drawable/domino_mask_24"
                        app:tint="@color/button_mask" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:padding="11dp"
                        android:src="@drawable/movie_24"
                        app:tint="@color/button_text" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/privatePhotoTab"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|bottom"
                        android:src="@drawable/domino_mask_24"
                        app:tint="@color/button_mask" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:padding="11dp"
                        android:src="@drawable/photo_24"
                        app:tint="@color/button_text" />
                </FrameLayout>

            </com.lollipop.common.ui.view.TabGroup>

        </eightbitlab.com.blurview.BlurView>
    </com.lollipop.common.ui.view.RoundOutlineLayout>

    <com.lollipop.common.ui.view.RoundOutlineLayout
        android:id="@+id/mfBtn"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@color/button_background"
        android:elevation="10dp"
        app:layout_constraintEnd_toEndOf="@+id/endGuideLine"
        app:layout_constraintTop_toTopOf="@id/topGuideLine">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/mfBtnBlur"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/mfBtnIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mf"
                app:tint="@color/button_text" />

        </eightbitlab.com.blurview.BlurView>

    </com.lollipop.common.ui.view.RoundOutlineLayout>

    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/menuBtnGroup"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:flexDirection="row_reverse"
        app:flexWrap="wrap"
        app:layout_constraintEnd_toStartOf="@id/mfBtn"
        app:layout_constraintStart_toEndOf="@id/startGuideLine"
        app:layout_constraintTop_toTopOf="@id/topGuideLine"
        tools:visibility="visible">

        <com.lollipop.common.ui.view.RoundOutlineLayout
            android:id="@+id/menuBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/button_background"
            app:layout_constraintEnd_toEndOf="@+id/endGuideLine"
            app:layout_constraintTop_toTopOf="@id/topGuideLine">

            <eightbitlab.com.blurview.BlurView
                android:id="@+id/menuBtnBlur"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/menuBtnIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/more_vert_24"
                    app:tint="@color/button_text" />

            </eightbitlab.com.blurview.BlurView>

        </com.lollipop.common.ui.view.RoundOutlineLayout>

        <com.lollipop.common.ui.view.RoundOutlineLayout
            android:id="@+id/topBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/button_background"
            app:layout_constraintEnd_toEndOf="@+id/endGuideLine"
            app:layout_constraintTop_toTopOf="@id/topGuideLine">

            <eightbitlab.com.blurview.BlurView
                android:id="@+id/topBtnBlur"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/topBtnIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/arrow_circle_up_24"
                    app:tint="@color/button_text" />

            </eightbitlab.com.blurview.BlurView>

        </com.lollipop.common.ui.view.RoundOutlineLayout>


        <com.lollipop.common.ui.view.RoundOutlineLayout
            android:id="@+id/sortBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/button_background"
            app:layout_constraintEnd_toEndOf="@+id/endGuideLine"
            app:layout_constraintTop_toTopOf="@id/topGuideLine">

            <eightbitlab.com.blurview.BlurView
                android:id="@+id/sortBtnBlur"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/sortBtnIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/text_arrow_down_24"
                    app:tint="@color/button_text" />

            </eightbitlab.com.blurview.BlurView>

        </com.lollipop.common.ui.view.RoundOutlineLayout>

        <com.lollipop.common.ui.view.RoundOutlineLayout
            android:id="@+id/dirBtn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/button_background"
            app:layout_constraintEnd_toEndOf="@+id/endGuideLine"
            app:layout_constraintTop_toTopOf="@id/topGuideLine">

            <eightbitlab.com.blurview.BlurView
                android:id="@+id/dirBtnBlur"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/dirBtnIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/folder_open_24"
                    app:tint="@color/button_text" />

            </eightbitlab.com.blurview.BlurView>

        </com.lollipop.common.ui.view.RoundOutlineLayout>

    </com.google.android.flexbox.FlexboxLayout>

</androidx.constraintlayout.widget.ConstraintLayout>