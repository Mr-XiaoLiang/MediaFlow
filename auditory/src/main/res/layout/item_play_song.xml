<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="#7DA2A9">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startGuideLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endGuideLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topGuideLine"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottomGuideLine"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="16dp" />

    <TextView
        android:id="@+id/pageNumberView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:textColor="@color/play_button_tint"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/endGuideLine"
        app:layout_constraintTop_toBottomOf="@id/topGuideLine"
        tools:text="01/12" />

    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/tagGroup"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        app:flexDirection="row"
        app:flexWrap="wrap"
        app:layout_constraintEnd_toStartOf="@id/pageNumberView"
        app:layout_constraintStart_toEndOf="@id/startGuideLine"
        app:layout_constraintTop_toTopOf="@id/topGuideLine">

        <com.lollipop.common.ui.view.TagTextView
            android:id="@+id/sizeTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="6dp"
            android:color="@color/play_button_tint"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:radius="4dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="1080 x 1920"
            tools:visibility="visible" />

        <com.lollipop.common.ui.view.TagTextView
            android:id="@+id/durationTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="6dp"
            android:color="@color/play_button_tint"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:radius="4dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="12:34"
            tools:visibility="visible" />

        <com.lollipop.common.ui.view.TagTextView
            android:id="@+id/formatTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="6dp"
            android:color="@color/play_button_tint"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:radius="4dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="MP4"
            tools:visibility="visible" />

    </com.google.android.flexbox.FlexboxLayout>

    <Space
        android:id="@+id/playAnchor"
        android:layout_width="68dp"
        android:layout_height="68dp"
        app:layout_constraintBottom_toTopOf="@id/bottomGuideLine"
        app:layout_constraintEnd_toStartOf="@id/endGuideLine"
        app:layout_constraintHorizontal_bias="0.7"
        app:layout_constraintStart_toEndOf="@id/startGuideLine"
        app:layout_constraintTop_toBottomOf="@id/topGuideLine"
        app:layout_constraintVertical_bias="0.85" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/coverImageView"
        android:layout_width="0px"
        android:layout_height="0px"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="@id/startGuideLine"
        app:layout_constraintTop_toBottomOf="@id/tagGroup"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="0px"
        android:layout_height="0px"
        android:autoSizeMaxTextSize="120sp"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeTextType="uniform"
        app:layout_constraintBottom_toBottomOf="@id/playAnchor"
        app:layout_constraintEnd_toEndOf="@id/endGuideLine"
        app:layout_constraintStart_toStartOf="@id/startGuideLine"
        app:layout_constraintTop_toBottomOf="@id/coverImageView"
        tools:text="我来试试中文字" />

</androidx.constraintlayout.widget.ConstraintLayout>