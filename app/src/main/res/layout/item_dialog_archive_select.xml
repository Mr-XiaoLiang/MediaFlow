<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp"
    android:paddingStart="6dp"
    android:paddingEnd="16dp">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/archiveBasketIconView"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:src="@drawable/archive_24"
        android:text="@string/label_archive_drag"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/button_text" />

    <TextView
        android:id="@+id/archiveBasketNameView"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginTop="8dp"
        android:textColor="@color/button_text"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@id/archiveBasketHintView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/archiveBasketIconView"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="archiveBasketNameView" />

    <TextView
        android:id="@+id/archiveBasketHintView"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="8dp"
        android:text="@string/label_archive_drag"
        android:textColor="@color/button_text"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/archiveBasketIconView" />

</androidx.constraintlayout.widget.ConstraintLayout>
