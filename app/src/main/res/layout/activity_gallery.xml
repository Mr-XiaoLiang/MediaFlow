<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:background="#3f00">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/startGuideLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/endGuideLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/topGuideLine"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="16dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottomGuideLine"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="16dp" />

    <FrameLayout
        android:id="@+id/galleryPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/galleryList"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:clipChildren="false"
            android:clipToPadding="false" />
    </FrameLayout>

    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="match_parent"
        android:layout_height="0px"
        app:layout_constraintBottom_toTopOf="@id/galleryPanel"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </eightbitlab.com.blurview.BlurTarget>

    <com.lollipop.mediaflow.ui.view.RoundOutlineLayout
        android:id="@+id/backBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@color/button_background"
        app:layout_constraintStart_toStartOf="@id/startGuideLine"
        app:layout_constraintTop_toTopOf="@id/topGuideLine">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/backBtnBlur"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:padding="6dp"
                android:src="@drawable/arrow_back_24"
                app:tint="@android:color/white" />

        </eightbitlab.com.blurview.BlurView>

    </com.lollipop.mediaflow.ui.view.RoundOutlineLayout>

    <com.lollipop.mediaflow.ui.view.RoundOutlineLayout
        android:id="@+id/menuBar"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:background="@color/button_background"
        app:layout_constraintEnd_toEndOf="@id/endGuideLine"
        app:layout_constraintTop_toTopOf="@id/topGuideLine">

        <eightbitlab.com.blurview.BlurView
            android:id="@+id/menuBarBlur"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/fullscreenBtn"
                    android:layout_width="42dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/fullscreen_24"
                    app:tint="@android:color/white" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/focusBtn"
                    android:layout_width="42dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/my_location_24"
                    app:tint="@android:color/white" />
            </LinearLayout>

        </eightbitlab.com.blurview.BlurView>

    </com.lollipop.mediaflow.ui.view.RoundOutlineLayout>

    <com.lollipop.mediaflow.ui.view.MarqueeTextView
        android:id="@+id/titleView"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:marqueeRepeatLimit="marquee_forever"
        android:shadowColor="@android:color/black"
        android:shadowRadius="3"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/tagGroup"
        app:layout_constraintEnd_toStartOf="@id/menuBar"
        app:layout_constraintStart_toEndOf="@id/backBtn"
        app:layout_constraintTop_toTopOf="@id/backBtn"
        tools:text="Test NameTest NameTest NameTest NameTest NameTest Name" />

    <LinearLayout
        android:id="@+id/tagGroup"
        android:layout_width="0px"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/backBtn"
        app:layout_constraintEnd_toStartOf="@id/menuBar"
        app:layout_constraintStart_toEndOf="@id/backBtn"
        app:layout_constraintTop_toBottomOf="@id/titleView">

        <com.lollipop.mediaflow.ui.view.TagTextView
            android:id="@+id/sizeTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:color="#DDFFFFFF"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:radius="4dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="1080 x 1920"
            tools:visibility="visible" />

        <com.lollipop.mediaflow.ui.view.TagTextView
            android:id="@+id/durationTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:color="#DDFFFFFF"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:radius="4dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="12:34"
            tools:visibility="visible" />

        <com.lollipop.mediaflow.ui.view.TagTextView
            android:id="@+id/formatTagView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:color="#DDFFFFFF"
            android:gravity="center"
            android:paddingHorizontal="4dp"
            android:radius="4dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="MP4"
            tools:visibility="visible" />

    </LinearLayout>

    <androidx.constraintlayout.widget.Group
        android:id="@+id/decorationPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:constraint_referenced_ids="menuBar,backBtn,titleView,tagGroup" />

</androidx.constraintlayout.widget.ConstraintLayout>