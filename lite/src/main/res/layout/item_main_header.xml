<?xml version="1.0" encoding="utf-8"?>
<com.lollipop.common.ui.view.RatioFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:ratio="2.0">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.lollipop.common.ui.view.RoundOutlineLayout
            android:id="@+id/menuBar"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:background="@color/button_background">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/sortBtn"
                    android:layout_width="42dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/text_arrow_down_24"
                    app:tint="@color/button_text" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/menuBtn"
                    android:layout_width="42dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:padding="6dp"
                    android:src="@drawable/more_vert_24"
                    app:tint="@color/button_text" />

            </LinearLayout>

        </com.lollipop.common.ui.view.RoundOutlineLayout>
    </FrameLayout>

</com.lollipop.common.ui.view.RatioFrameLayout>